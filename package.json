{
  "name": "termination",
  "version": "1.0.0",
  "bin": "index.js",
  "scripts": {
    "build": "pkg . --out-path dist --targets node18-macos-x64,node18-macos-arm64,node18-linux-x64,node18-linux-arm64",
    "upload": "bash scripts/upload-release.sh"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "ajv": "^8.18.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "tools/**/*",
      "scripts/**/*",
      "shell-controllers/**/*",
      "node_modules/@xenova/transformers/**/*",
      "node_modules/onnxruntime-node/**/*"
    ],
    "scripts": [
      "node_modules/@xenova/transformers/src/*.js"
    ]
  }
}