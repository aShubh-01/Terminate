{
  "extract": {
    "description": "Extract JSON object from any string",

    "type": "object",

    "required": ["text"],

    "properties": {
      "text": {
        "type": "string",
        "description": "String containing JSON"
      }
    },

    "examples": [
      ":json.extract text=\"hello {name:'shubham'} world\"",
      ":json.extract \"some text {age:21}\""
    ]
  }
}