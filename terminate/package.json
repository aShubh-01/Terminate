{
  "name": "terminate",
  "version": "1.0.0",
  "bin": "index.js",
  "scripts": {
    "build-bin": "pkg . --out-path publish/dist --targets node18-macos-x64,node18-macos-arm64,node18-linux-x64,node18-linux-arm64,node18-win-x64,node18-win-arm64",
    "bundle-source": "COPYFILE_DISABLE=1 tar -czf publish/source/terminate-source.tar.gz tools scripts index.js package.json README.md config.json",
    "fetch-runtimes": "bash publish/files/fetch-runtimes.sh",
    "upload": "node publish/files/upload.js"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "ajv": "^8.18.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "tools/**/*",
      "scripts/**/*",
      "shell-controllers/**/*",
      "node_modules/@xenova/transformers/**/*",
      "node_modules/onnxruntime-node/**/*"
    ],
    "scripts": [
      "node_modules/@xenova/transformers/src/*.js"
    ]
  }
}
