# ── Terminate Server Environment ─────────────────────────────
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-real-secret
JWT_EXPIRES_IN=30d

# Database
DATABASE_URL=

# AI (System-provided)
SYSTEM_AI_KEY=
SYSTEM_AI_MODEL=deepseek-chat
SYSTEM_AI_BASE_URL=https://api.deepseek.com

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
