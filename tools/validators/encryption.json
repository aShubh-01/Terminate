{
  "encrypt": {
    "description": "Encrypt a string or object using AES-128-CBC",

    "type": "object",

    "required": ["input"],

    "properties": {
      "input": {
        "type": ["string", "object"],
        "description": "Data to encrypt"
      },

      "key": {
        "type": "string",
        "description": "Optional secret key in hex format"
      }
    },

    "examples": [
      ":encryption.encrypt input=\"hello\"",
      ":encryption.encrypt {name:\"Shubham\",age:21}"
    ]
  },

  "decrypt": {
    "description": "Decrypt ciphertext generated by encryption.encrypt",

    "type": "object",

    "required": ["input"],

    "properties": {
      "input": {
        "type": "string",
        "description": "Ciphertext string"
      },

      "key": {
        "type": "string",
        "description": "Optional secret key"
      }
    },

    "examples": [
      ":encryption.decrypt input=\"ciphertext\""
    ]
  }
}